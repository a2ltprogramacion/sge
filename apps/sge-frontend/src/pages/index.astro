---
// SGE Frontend - Landing Page
import Layout from '@/layouts/Layout.astro';
---

<Layout title="SGE - Sistema de Gestión Escolar">
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-gray-900 dark:to-gray-800">
    <div class="text-center px-6">
      <h1 class="text-5xl font-bold text-gray-900 dark:text-white mb-6">SGE</h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 mb-8 max-w-2xl mx-auto">
        Sistema de Gestión Escolar - Cloudflare Pages + Workers + D1 + R2
      </p>
      <div class="space-x-4">
        <a href="/login" class="inline-block px-8 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
          Iniciar Sesión
        </a>
        <a href="/docs" class="inline-block px-8 py-3 border-2 border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition-colors dark:hover:bg-blue-900/20">
          Documentación
        </a>
      </div>
    </div>
  </main>
</Layout>
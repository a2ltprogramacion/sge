{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@sge/*": ["packages/*/src"],
      "@sge-api/*": ["apps/sge-api/src/*"],
      "@sge-frontend/*": ["apps/sge-frontend/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".astro", ".wrangler", ".turbo", "coverage"]
}
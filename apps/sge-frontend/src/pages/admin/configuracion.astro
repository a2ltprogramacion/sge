---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/navigation/Navigation.astro';

const user = Astro.locals.user as {
  id: string;
  email: string;
  rol: string;
  nombres: string;
  apellidos: string;
};
---

<Layout title="Configuración del Plantel" description="Administrar configuración general del plantel educativo">
  <main id="main-content" class="flex-1 container mx-auto px-4 py-8">
    <Navigation userRole="ADMINISTRADOR" userName={`${user.nombres} ${user.apellidos}`} />

    <div class="max-w-3xl mx-auto">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-text-main mb-2">Configuración del Plantel</h1>
        <p class="text-text-muted">Administrar configuración general del sistema</p>
      </div>

      <div class="card mb-8">
        <div class="card-body">
          <form id="config-form" class="space-y-6">
            <div>
              <label class="label" for="nombre_plantel">Nombre del Plantel</label>
              <input id="nombre_plantel" name="nombre_plantel" type="text" class="input w-full" required />
            </div>

            <div>
              <label class="label" for="periodo_id">Año Escolar Activo</label>
              <select id="periodo_id" name="periodo_id" class="input w-full" required>
                <option value="">Cargando periodos...</option>
              </select>
            </div>

            <div>
              <label class="label" for="sistema_evaluacion">Sistema de Evaluación por Defecto</label>
              <select id="sistema_evaluacion" name="sistema_evaluacion" class="input w-full">
                <option value="NUMERICO_20">Numérico (0–20)</option>
                <option value="CUALITATIVO_AE">Cualitativo (A–E)</option>
              </select>
            </div>

            <div>
              <label class="label" for="telefono">Teléfono de Contacto</label>
              <input id="telefono" name="telefono" type="tel" class="input w-full" />
            </div>

            <div>
              <label class="label" for="direccion">Dirección</label>
              <textarea id="direccion" name="direccion" class="input w-full" rows="3"></textarea>
            </div>

            <div class="flex items-center gap-4">
              <button type="submit" id="btn-save" class="btn btn-primary">
                Guardar Configuración
              </button>
              <span id="save-message" class="hidden text-sm"></span>
            </div>
          </form>
        </div>
      </div>

      <div class="card mb-8" id="sistemas-section">
        <div class="card-header flex items-center justify-between">
          <h2 class="text-xl font-semibold text-text-main">Sistemas de Evaluación</h2>
          <button id="btn-nuevo-sistema" class="btn btn-primary btn-sm">+ Nuevo</button>
        </div>
        <div class="card-body">
          <div id="sistemas-loading" class="text-sm text-text-muted">Cargando sistemas...</div>
          <div id="sistemas-table-wrapper" class="hidden overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="text-left text-text-muted text-sm">
                  <th class="pb-3 font-medium">Nombre</th>
                  <th class="pb-3 font-medium">Tipo</th>
                  <th class="pb-3 font-medium">Estado</th>
                  <th class="pb-3 font-medium">Acciones</th>
                </tr>
              </thead>
              <tbody id="sistemas-tbody" class="divide-y divide-border"></tbody>
            </table>
          </div>
          <div id="sistemas-empty" class="hidden text-center py-4 text-text-muted">
            <p>No hay sistemas personalizados. Crea uno nuevo.</p>
          </div>
        </div>
      </div>

      <!-- Modal nuevo sistema de evaluación -->
      <div id="modal-sistema" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
        <div class="card w-full max-w-md mx-auto">
          <div class="card-header flex items-center justify-between">
            <h2 class="text-xl font-semibold text-text-main" id="modal-sistema-title">Nuevo Sistema de Evaluación</h2>
            <button id="btn-cerrar-modal-sistema" class="text-text-muted hover:text-text-main">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>
          <form id="form-sistema" class="card-body space-y-4">
            <div>
              <label class="label" for="input-sis-nombre">Nombre del Sistema</label>
              <input id="input-sis-nombre" type="text" class="input w-full" required placeholder="Ej: Escala Personalizada" />
            </div>
            <div>
              <label class="label" for="input-sis-descripcion">Descripción</label>
              <textarea id="input-sis-descripcion" class="input w-full" rows="2" placeholder="Opcional"></textarea>
            </div>
            <div>
              <label class="label" for="input-sis-tipo">Tipo</label>
              <select id="input-sis-tipo" class="input w-full" required>
                <option value="NUMERICO">Numérico</option>
                <option value="CUALITATIVO">Cualitativo (A–E)</option>
              </select>
            </div>
            <div id="modal-sistema-error" class="hidden text-sm text-error-600"></div>
            <div class="flex justify-end gap-3">
              <button type="button" id="btn-cancelar-sistema" class="btn btn-secondary">Cancelar</button>
              <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
          </form>
        </div>
      </div>

      <div id="loading-state" class="text-center py-8 text-text-muted">
        <p>Cargando configuración...</p>
      </div>
      <div id="error-state" class="hidden text-center py-8 text-error-600">
        <p id="error-message">Error al cargar la configuración.</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { apiGet, apiFetch } from '@/lib/api';

  const form = document.getElementById('config-form');
  const btnSave = document.getElementById('btn-save');
  const saveMessage = document.getElementById('save-message');
  const loadingState = document.getElementById('loading-state');
  const errorState = document.getElementById('error-state');
  const errorMessage = document.getElementById('error-message');

  function showError(msg) {
    loadingState.classList.add('hidden');
    errorState.classList.remove('hidden');
    errorMessage.textContent = msg;
  }

  function setMessage(msg, type) {
    saveMessage.textContent = msg;
    saveMessage.className = `text-sm ${type === 'success' ? 'text-success-600' : 'text-error-600'}`;
    saveMessage.classList.remove('hidden');
    setTimeout(() => saveMessage.classList.add('hidden'), 5000);
  }

  async function loadConfig() {
    try {
      const [config, periodos] = await Promise.all([
        apiGet('/api/admin/configuracion'),
        apiGet('/api/admin/periodos'),
      ]);

      document.getElementById('nombre_plantel').value = config.nombre_plantel || '';
      document.getElementById('telefono').value = config.telefono_contacto || config.telefono || '';
      document.getElementById('direccion').value = config.direccion || '';
      document.getElementById('sistema_evaluacion').value = config.sistema_evaluacion_por_defecto || config.sistema_evaluacion || 'NUMERICO_20';

      const periodoSelect = document.getElementById('periodo_id');
      const periodosList = periodos.periodos || periodos;
      periodoSelect.innerHTML = periodosList.map(p =>
        `<option value="${p.id}" ${p.activo ? 'selected' : ''}>${p.nombre}</option>`
      ).join('');

      loadingState.classList.add('hidden');
    } catch (err) {
      showError('Error al cargar configuración: ' + err.message);
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btnSave.disabled = true;
    btnSave.innerHTML = 'Guardando...';
    saveMessage.classList.add('hidden');

    try {
      const data = {
        nombre_plantel: document.getElementById('nombre_plantel').value,
        telefono_contacto: document.getElementById('telefono').value,
        direccion: document.getElementById('direccion').value,
        sistema_evaluacion_por_defecto: document.getElementById('sistema_evaluacion').value,
      };

      await apiFetch('/api/admin/configuracion', {
        method: 'PATCH',
        body: JSON.stringify(data),
      });

      setMessage('Configuración guardada exitosamente.', 'success');
    } catch (err) {
      setMessage('Error al guardar: ' + err.message, 'error');
    } finally {
      btnSave.disabled = false;
      btnSave.innerHTML = 'Guardar Configuración';
    }
  });

  loadConfig();

  // === Sistemas de Evaluación ===
  const sistemasTbody = document.getElementById('sistemas-tbody');
  const sistemasLoading = document.getElementById('sistemas-loading');
  const sistemasTableWrapper = document.getElementById('sistemas-table-wrapper');
  const sistemasEmpty = document.getElementById('sistemas-empty');

  function renderSistemas(sistemas) {
    const custom = sistemas.filter(s => s.codigo.startsWith('CUSTOM_'));
    if (custom.length === 0) {
      sistemasTableWrapper.classList.add('hidden');
      sistemasEmpty.classList.remove('hidden');
      return;
    }
    sistemasEmpty.classList.add('hidden');
    sistemasTableWrapper.classList.remove('hidden');
    sistemasTbody.innerHTML = custom.map(s => `
      <tr>
        <td class="py-3 font-medium text-text-main">${s.nombre} <span class="text-xs text-text-muted">${s.descripcion ? '- ' + s.descripcion : ''}</span></td>
        <td class="py-3 text-text-main">${s.tipo}</td>
        <td class="py-3">${s.activo ? '<span class="badge badge-success">Activo</span>' : '<span class="badge badge-error">Inactivo</span>'}</td>
        <td class="py-3">
          <button class="btn btn-sm btn-outline-error eliminar-sistema" data-id="${s.id}">Eliminar</button>
        </td>
      </tr>
    `).join('');

    sistemasTbody.querySelectorAll('.eliminar-sistema').forEach(btn => {
      btn.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este sistema de evaluación?')) return;
        try {
          await apiFetch(`/api/admin/sistemas-evaluacion/${btn.dataset.id}`, { method: 'DELETE' });
          loadSistemas();
        } catch (err) { alert('Error: ' + err.message); }
      });
    });
  }

  async function loadSistemas() {
    try {
      const data = await apiGet('/api/admin/sistemas-evaluacion');
      renderSistemas(data.sistemas);
      // Populate dropdown
      const select = document.getElementById('sistema_evaluacion');
      const currentVal = select.value;
      select.innerHTML = data.sistemas.map(s =>
        `<option value="${s.codigo}" ${s.codigo === currentVal ? 'selected' : ''}>${s.nombre}</option>`
      ).join('');
    } catch (err) {
      sistemasLoading.textContent = 'Error: ' + err.message;
    }
  }

  // Modal sistema
  const modalSistema = document.getElementById('modal-sistema');
  document.getElementById('btn-nuevo-sistema').addEventListener('click', () => {
    document.getElementById('form-sistema').reset();
    document.getElementById('modal-sistema-error').classList.add('hidden');
    modalSistema.classList.remove('hidden');
  });
  const cerrarSistema = () => modalSistema.classList.add('hidden');
  document.getElementById('btn-cerrar-modal-sistema').addEventListener('click', cerrarSistema);
  document.getElementById('btn-cancelar-sistema').addEventListener('click', cerrarSistema);
  modalSistema.addEventListener('click', (e) => { if (e.target === modalSistema) cerrarSistema(); });

  document.getElementById('form-sistema').addEventListener('submit', async (e) => {
    e.preventDefault();
    const modalError = document.getElementById('modal-sistema-error');
    modalError.classList.add('hidden');
    const data = {
      nombre: document.getElementById('input-sis-nombre').value.trim(),
      descripcion: document.getElementById('input-sis-descripcion').value.trim(),
      tipo: document.getElementById('input-sis-tipo').value,
    };
    if (!data.nombre) { modalError.textContent = 'El nombre es obligatorio.'; modalError.classList.remove('hidden'); return; }
    try {
      await apiFetch('/api/admin/sistemas-evaluacion', { method: 'POST', body: JSON.stringify(data) });
      cerrarSistema();
      loadSistemas();
    } catch (err) { modalError.textContent = 'Error: ' + err.message; modalError.classList.remove('hidden'); }
  });

  loadSistemas();
</script>

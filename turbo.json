{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "sge-frontend#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "sge-api#build": {
      "dependsOn": ["sge-frontend#build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "lint": {
      "outputs": []
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  },
  "globalEnv": ["NODE_ENV", "WRANGLER_SEND_METRICS"]
}
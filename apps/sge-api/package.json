{
  "name": "sge-api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "db:generate": "wrangler d1 migrations create sge-db-prod",
    "db:migrate": "wrangler d1 migrations apply sge-db-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply sge-db-prod --remote",
    "db:seed": "wrangler d1 execute sge-db-prod --local --file=../../packages/database/seeds/seed-all.sql",
    "db:seed:remote": "wrangler d1 execute sge-db-prod --remote --file=../../packages/database/seeds/seed-all.sql"
  },
  "dependencies": {
    "hono": "^4.5.0",
    "zod": "^3.23.0",
    "jose": "^5.6.0",
    "web-push": "^3.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240800.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.70.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}